{
  "expo": {
    "name": "iTala",
    "slug": "itala",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "itala",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0F18"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.bpbl.itala",
      "buildNumber": "1",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      },
      "usesAppleSignIn": true
    },
    "android": {
      "package": "com.bpbl.itala",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A0F18"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "iTala lets you choose a photo from your library to use as a team logo."
        }
      ],
      "expo-apple-authentication",
      [
        "expo-notifications",
        {
          "color": "#12D7D0"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "bf4508b7-20f9-4342-a315-9b6f6121aef9"
      }
    }
  }
}
