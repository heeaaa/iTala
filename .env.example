# iTala — Supabase configuration (optional)
#
# Copy this file to `.env` and fill in values from your Supabase project
# (Dashboard → Project Settings → API). With both values set, the app runs in
# SYNCED mode. With either missing, it runs in LOCAL-ONLY mode (single device).
#
# EXPO_PUBLIC_* vars are inlined into the JS bundle by Metro, so they're safe
# to put here for local development. The ANON key is safe to ship in the client
# binary — row-level security on the database is what actually protects writes.

EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
